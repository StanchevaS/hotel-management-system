@model Hotel.Models.ApplicationUser

@{
    ViewData["Title"] = "Редакция на потребител";
    var roles = ViewBag.UserRoles as IList<string> ?? new List<string>();
    bool isCurrentUser = ViewBag.IsCurrentUser != null && (bool)ViewBag.IsCurrentUser;
}

<div class="card-style">
    <h1 class="page-title">Редакция на потребител</h1>

    @if (isCurrentUser)
    {
        <div class="alert alert-info">
            Редактирате собствения си профил.
        </div>
    }

    <form asp-action="EditUser" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" value="@Model.Id" />

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label class="form-label">Имейл</label>
            <input type="email" name="email" class="form-control" value="@Model.Email" />
        </div>

        <div class="mb-3">
            <label class="form-label">Роля</label>
            <input type="text" class="form-control" value="@string.Join(", ", roles)" readonly />
            <div class="form-text">
                Ролята се показва само за информация и не се променя от този екран.
            </div>
        </div>

        <div class="mb-3">
            <label class="form-label">Нова парола</label>
            <input type="password" name="newPassword" class="form-control" />
            <div class="form-text">
                Оставете празно, ако не искате да сменяте паролата.
            </div>
        </div>

        <div class="d-flex gap-2 flex-wrap">
            <button type="submit" class="btn btn-primary">Запази</button>
            <a asp-action="Users" class="btn btn-secondary">Назад</a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}