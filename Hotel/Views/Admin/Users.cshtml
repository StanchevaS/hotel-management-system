@model List<(Hotel.Models.ApplicationUser User, IList<string> Roles)>

@{
    ViewData["Title"] = "Потребители";
    var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
}

<div class="card-style">
    <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
        <h1 class="page-title mb-0">Потребители</h1>
        <a asp-action="CreateUser" class="btn btn-primary">Нов потребител</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <div class="table-responsive">
        <table class="table table-bordered align-middle">
            <thead>
                <tr>
                    <th>Имейл</th>
                    <th>Роли</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        var isCurrentUser = item.User.Id == currentUserId;
                        var isReceptionist = item.Roles.Contains("Receptionist");
                        var isAdministrator = item.Roles.Contains("Administrator");

                        <tr>
                            <td>
                                @item.User.Email
                                @if (isCurrentUser)
                                {
                                    <span class="badge bg-secondary ms-2">Ваш профил</span>
                                }
                            </td>
                            <td>@string.Join(", ", item.Roles)</td>
                            <td>
                                <a asp-action="EditUser"
                                   asp-route-id="@item.User.Id"
                                   class="btn btn-sm btn-warning me-1">
                                    Редактирай
                                </a>

                                @if (isReceptionist)
                                {
                                    <form asp-action="DeleteUser" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.User.Id" />
                                        <button type="submit"
                                                class="btn btn-sm btn-danger"
                                                onclick="return confirm('Сигурни ли сте, че искате да изтриете този потребител?');">
                                            Изтрий
                                        </button>
                                    </form>
                                }
                                else if (isCurrentUser && isAdministrator)
                                {
                                    <span class="text-muted small">Собственият администраторски профил не може да се изтрие.</span>
                                }
                                else
                                {
                                    <span class="text-muted small">Администраторски профил не се изтрива.</span>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="3" class="text-center text-muted">Няма потребители.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>