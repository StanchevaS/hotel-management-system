@{
    ViewData["Title"] = "Контакти";
}

<div class="accommodation-page">

    <section class="accommodation-hero card-style mb-4">
        <div class="row">
            <div class="col-lg-12">
                <span class="accommodation-kicker">Hotel Golden Breeze</span>
                <h1 class="accommodation-title">Контакти</h1>
            </div>
        </div>
    </section>

    <section class="contacts-panel-section mb-4">
        <div class="hotel-contact-panel-wrap">
            <div class="hotel-contact-panel">

                <p class="hotel-contact-panel-text">
                    За резервация или въпрос можете да използвате и формата за запитване.
                </p>

                <div class="hotel-contact-panel-list">
                    <div class="hotel-contact-panel-item">
                        <span class="hotel-contact-panel-label">Телефон</span>
                        <div class="hotel-contact-panel-value">+359 000 000 000</div>
                    </div>

                    <div class="hotel-contact-panel-item">
                        <span class="hotel-contact-panel-label">Имейл</span>
                        <div class="hotel-contact-panel-value">info@goldenbreezehotel.com</div>
                    </div>

                    <div class="hotel-contact-panel-item">
                        <span class="hotel-contact-panel-label">Адрес</span>
                        <div class="hotel-contact-panel-value">к.к. Златни пясъци, 9007 Варна, България</div>
                    </div>

                    <div class="hotel-contact-panel-item">
                        <span class="hotel-contact-panel-label">Рецепция</span>
                        <div class="hotel-contact-panel-value">
                            24/7
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

</div>