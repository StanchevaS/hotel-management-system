@model Hotel.Models.Inquiry

@{
    ViewData["Title"] = "Изтриване на запитване";

    var badgeClass = Model.Status switch
    {
        "Ново" => "bg-primary",
        "Обработва се" => "bg-warning text-dark",
        "Обработено" => "bg-success",
        "Отказано" => "bg-danger",
        "Превърнато в резервация" => "bg-secondary",
        _ => "bg-dark"
    };
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="mb-0 text-danger">Изтриване на запитване</h1>
        <a asp-action="Index" class="btn btn-outline-secondary">Назад към запитванията</a>
    </div>

    <div class="alert alert-warning">
        Сигурни ли сте, че искате да изтриете това запитване?
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <div><strong>Име:</strong> @Model.Name</div>
                    <div><strong>Телефон:</strong> @Model.Phone</div>
                    <div><strong>Брой гости:</strong> @Model.GuestsCount</div>
                </div>

                <div class="col-md-6">
                    <div><strong>Настаняване:</strong> @Model.CheckIn.ToString("dd.MM.yyyy")</div>
                    <div><strong>Напускане:</strong> @Model.CheckOut.ToString("dd.MM.yyyy")</div>
                    <div>
                        <strong>Статус:</strong>
                        <span class="badge @badgeClass">@Model.Status</span>
                    </div>
                </div>

                <div class="col-12">
                    <div><strong>Предпочитана стая:</strong> @(string.IsNullOrWhiteSpace(Model.PreferredRoom) ? "-" : Model.PreferredRoom)</div>
                </div>

                <div class="col-12">
                    <div><strong>Съобщение:</strong></div>
                    <div class="border rounded p-3 bg-light" style="white-space: pre-line;">
                        @(string.IsNullOrWhiteSpace(Model.Message) ? "Няма въведено съобщение." : Model.Message)
                    </div>
                </div>
            </div>

            <form asp-action="Delete" method="post">
                @Html.AntiForgeryToken()
                <input asp-for="Id" type="hidden" />

                <div class="d-flex flex-wrap gap-2">
                    <button type="submit" class="btn btn-danger">
                        Да, изтрий
                    </button>

                    <a asp-action="Index" class="btn btn-outline-secondary">
                        Отказ
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>