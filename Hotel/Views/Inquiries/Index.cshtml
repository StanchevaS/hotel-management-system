@model IEnumerable<Hotel.Models.Inquiry>

@{
    ViewData["Title"] = "Запитвания";
}

<div class="container py-4">
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-2">
        <h1 class="mb-0">Запитвания</h1>
        <a asp-controller="Reservations" asp-action="Create" class="btn btn-primary">
            Нова резервация
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">
            @TempData["SuccessMessage"]
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">
            @TempData["ErrorMessage"]
        </div>
    }

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            Няма налични запитвания.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Име</th>
                        <th>Телефон</th>
                        <th>Настаняване</th>
                        <th>Напускане</th>
                        <th>Гости</th>
                        <th>Предпочитана стая</th>
                        <th>Статус</th>
                        <th>Създадено на</th>
                        <th class="text-end">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Name</td>
                            <td>@item.Phone</td>
                            <td>@item.CheckIn.ToString("dd.MM.yyyy")</td>
                            <td>@item.CheckOut.ToString("dd.MM.yyyy")</td>
                            <td>@item.GuestsCount</td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(item.PreferredRoom))
                                {
                                    @item.PreferredRoom
                                }
                                else
                                {
                                    <span>-</span>
                                }
                            </td>
                            <td>
                                @{
                                    var badgeClass = item.Status switch
                                    {
                                        "Ново" => "bg-primary",
                                        "Обработва се" => "bg-warning text-dark",
                                        "Обработено" => "bg-success",
                                        "Отказано" => "bg-danger",
                                        "Превърнато в резервация" => "bg-secondary",
                                        _ => "bg-dark"
                                    };
                                }

                                <span class="badge @badgeClass">@item.Status</span>
                            </td>
                            <td>@item.CreatedOn.ToString("dd.MM.yyyy HH:mm")</td>
                            <td class="text-end">
                                <div class="d-flex flex-wrap justify-content-end gap-1">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">
                                        Детайли
                                    </a>

                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">
                                        Редакция
                                    </a>

                                    @if (item.Status != "Превърнато в резервация" && item.Status != "Отказано")
                                    {
                                        <a asp-controller="Reservations"
                                           asp-action="Create"
                                           asp-route-inquiryId="@item.Id"
                                           asp-route-guestName="@item.Name"
                                           asp-route-phone="@item.Phone"
                                           asp-route-checkIn="@item.CheckIn.ToString("yyyy-MM-dd")"
                                           asp-route-checkOut="@item.CheckOut.ToString("yyyy-MM-dd")"
                                           asp-route-guestsCount="@item.GuestsCount"
                                           asp-route-preferredRoomNumber="@item.PreferredRoom"
                                           class="btn btn-sm btn-primary">
                                            Превърни в резервация
                                        </a>
                                    }

                                    @if (User.IsInRole("Administrator"))
                                    {
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">
                                            Изтрий
                                        </a>
                                    }
                                </div>
                            </td>
                        </tr>

                        @if (!string.IsNullOrWhiteSpace(item.Message))
                        {
                            <tr class="table-light">
                                <td colspan="9">
                                    <strong>Съобщение:</strong> @item.Message
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    }
</div>