@model Hotel.Models.ReportFilter

@{
    ViewData["Title"] = "Заетост";
    int totalRooms = ViewBag.TotalRooms != null ? (int)ViewBag.TotalRooms : 0;
    int totalDays = ViewBag.TotalDays != null ? (int)ViewBag.TotalDays : 0;
    int occupiedRoomDays = ViewBag.OccupiedRoomDays != null ? (int)ViewBag.OccupiedRoomDays : 0;
    decimal occupancyPercent = ViewBag.OccupancyPercent != null ? (decimal)ViewBag.OccupancyPercent : 0m;
}

<div class="card-style mb-4">
    <h1 class="page-title">Справка за заетост</h1>
    <p class="hero-subtitle">
        Преглед на заетостта за избрания период. Стаите в ремонт не се включват в изчислението.
    </p>
</div>

<div class="card-style mb-4">
    <form asp-action="Occupancy" method="post" class="row g-3">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="col-md-4">
            <label asp-for="StartDate" class="form-label">Начална дата</label>
            <input asp-for="StartDate" type="date" class="form-control" />
            <span asp-validation-for="StartDate" class="text-danger"></span>
        </div>

        <div class="col-md-4">
            <label asp-for="EndDate" class="form-label">Крайна дата</label>
            <input asp-for="EndDate" type="date" class="form-control" />
            <span asp-validation-for="EndDate" class="text-danger"></span>
        </div>

        <div class="col-md-4 d-flex align-items-end">
            <button type="submit" class="btn btn-primary w-100">Покажи справката</button>
        </div>
    </form>
</div>

@if (occupiedRoomDays > 0 || totalRooms > 0 || totalDays > 0)
{
    <div class="row mb-4">
        <div class="col-md-3 mb-3">
            <div class="card-style text-center h-100">
                <h3>@totalRooms</h3>
                <p class="mb-0">Общ брой стаи</p>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card-style text-center h-100">
                <h3>@totalDays</h3>
                <p class="mb-0">Брой дни в периода</p>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card-style text-center h-100">
                <h3>@occupiedRoomDays</h3>
                <p class="mb-0">Заети нощувки по стаи</p>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card-style text-center h-100">
                <h3>@occupancyPercent.ToString("F2")%</h3>
                <p class="mb-0">Процент заетост</p>
            </div>
        </div>
    </div>
}
else if (Model?.StartDate != default && Model?.EndDate != default)
{
    <div class="card-style">
        <div class="alert alert-info mb-0">
            Няма достатъчно данни за избрания период.
        </div>
    </div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}