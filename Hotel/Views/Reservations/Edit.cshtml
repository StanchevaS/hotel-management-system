@model Hotel.Models.Reservation
@using Hotel.Helpers

@{
    ViewData["Title"] = "Редакция на резервация";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="mb-0">Редакция на резервация</h1>
        <a asp-action="Index" class="btn btn-outline-secondary">Назад към резервациите</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">
            @TempData["SuccessMessage"]
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">
            @TempData["ErrorMessage"]
        </div>
    }

    @if (!ViewData.ModelState.IsValid)
    {
        <div asp-validation-summary="All" class="alert alert-danger"></div>
    }

    <div class="card shadow-sm">
        <div class="card-body">
            <form asp-action="Edit" method="post" id="reservationForm">
                @Html.AntiForgeryToken()
                <input asp-for="Id" type="hidden" />

                <div class="row g-3">
                    <div class="col-md-4">
                        <label asp-for="GuestName" class="form-label">Име на гост</label>
                        <input asp-for="GuestName" class="form-control" />
                        <span asp-validation-for="GuestName" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="Phone" class="form-label">Телефон</label>
                        <input asp-for="Phone"
                               class="form-control"
                               inputmode="tel"
                               pattern="[0-9+\-\s()]+"
                               title="Телефонният номер може да съдържа само цифри, интервали, +, - и скоби." />
                        <span asp-validation-for="Phone" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Текущ статус</label>
                        <input class="form-control" value="@ReservationUiHelper.GetReservationStatusText(Model.Status)" readonly />
                    </div>

                    <div class="col-md-3">
                        <label asp-for="CheckIn" class="form-label">Настаняване</label>
                        <input asp-for="CheckIn" type="date" class="form-control" />
                        <span asp-validation-for="CheckIn" class="text-danger"></span>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="CheckOut" class="form-label">Напускане</label>
                        <input asp-for="CheckOut" type="date" class="form-control" />
                        <span asp-validation-for="CheckOut" class="text-danger"></span>
                    </div>

                    <div class="col-md-2">
                        <label asp-for="GuestsCount" class="form-label">Брой гости</label>
                        <input asp-for="GuestsCount" type="number" min="1" class="form-control" />
                        <span asp-validation-for="GuestsCount" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="RoomId" class="form-label">Стая</label>
                        <select asp-for="RoomId" class="form-select" asp-items="ViewBag.RoomList">
                            <option value="">-- изберете стая --</option>
                        </select>
                        <span asp-validation-for="RoomId" class="text-danger"></span>
                    </div>

                    <div class="col-md-4 d-flex align-items-end">
                        <div class="form-check mt-4">
                            <input asp-for="IsPaid" class="form-check-input" />
                            <label asp-for="IsPaid" class="form-check-label">Платено</label>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="TotalAmount" class="form-label">Сума</label>
                        <input asp-for="TotalAmount" class="form-control" readonly />
                        <div class="form-text">
                            Сумата се преизчислява автоматично според стаята и броя нощувки при запис.
                        </div>
                    </div>

                    <div class="col-12">
                        <div class="form-text">
                            Статусът се определя автоматично според датите на резервацията.
                        </div>
                    </div>

                    <div class="col-12">
                        <div class="d-flex flex-wrap gap-2 mt-3">
                            <button type="submit" class="btn btn-primary" id="saveReservationBtn">
                                Запази промените
                            </button>

                            <a asp-action="Index" class="btn btn-outline-secondary">
                                Назад
                            </a>
                        </div>
                    </div>
                </div>
            </form>

            @if (Model.Status != Hotel.Enums.ReservationStatus.Cancelled &&
                        Model.Status != Hotel.Enums.ReservationStatus.CheckedOut)
            {
                <form asp-action="Cancel" method="post" class="mt-3">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button type="submit"
                            class="btn btn-secondary"
                            onclick="return confirm('Сигурни ли сте, че искате да откажете тази резервация?');">
                        Откажи резервацията
                    </button>
                </form>
            }
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        (function () {
            const form = document.getElementById("reservationForm");
            const saveBtn = document.getElementById("saveReservationBtn");

            if (!form || !saveBtn) return;

            saveBtn.addEventListener("click", function (e) {
                const checkOutInput = document.getElementById("CheckOut");
                const isPaidInput = document.getElementById("IsPaid");

                if (!checkOutInput || !isPaidInput) return;

                const checkOutValue = checkOutInput.value;
                const isPaid = isPaidInput.checked;

                if (!checkOutValue || isPaid) return;

                const today = new Date();
                today.setHours(0, 0, 0, 0);

                const checkOutDate = new Date(checkOutValue + "T00:00:00");

                if (checkOutDate < today) {
                    const confirmed = confirm("Резервацията е за изминал период и не е отбелязана като платена. Сигурни ли сте, че искате да продължите?");

                    if (!confirmed) {
                        e.preventDefault();
                    }
                }
            });
        })();
    </script>
}