@model Hotel.Models.Reservation

@{
    ViewData["Title"] = "Редакция на резервация";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="mb-0">Редакция на резервация</h1>
        <a asp-action="Index" class="btn btn-outline-secondary">Назад към резервациите</a>
    </div>

    @if (!ViewData.ModelState.IsValid)
    {
        <div asp-validation-summary="All" class="alert alert-danger"></div>
    }

    <div class="card shadow-sm">
        <div class="card-body">
            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                <input asp-for="Id" type="hidden" />

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="GuestName" class="form-label">Име на гост</label>
                        <input asp-for="GuestName" class="form-control" />
                        <span asp-validation-for="GuestName" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Phone" class="form-label">Телефон</label>
                        <input asp-for="Phone"
                               class="form-control"
                               inputmode="tel"
                               pattern="[0-9+\-\s()]+"
                               title="Телефонният номер може да съдържа само цифри, интервали, +, - и скоби." />
                        <span asp-validation-for="Phone" class="text-danger"></span>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="CheckIn" class="form-label">Настаняване</label>
                        <input asp-for="CheckIn" type="date" class="form-control" />
                        <span asp-validation-for="CheckIn" class="text-danger"></span>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="CheckOut" class="form-label">Напускане</label>
                        <input asp-for="CheckOut" type="date" class="form-control" />
                        <span asp-validation-for="CheckOut" class="text-danger"></span>
                    </div>

                    <div class="col-md-2">
                        <label asp-for="GuestsCount" class="form-label">Брой гости</label>
                        <input asp-for="GuestsCount" type="number" min="1" class="form-control" />
                        <span asp-validation-for="GuestsCount" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="RoomId" class="form-label">Стая</label>
                        <select asp-for="RoomId" class="form-select" asp-items="ViewBag.RoomList">
                            <option value="">-- изберете стая --</option>
                        </select>
                        <span asp-validation-for="RoomId" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="Status" class="form-label">Статус</label>
                        <select asp-for="Status" class="form-select" id="Status">
                            @foreach (var status in Enum.GetValues(typeof(Hotel.Enums.ReservationStatus)).Cast<Hotel.Enums.ReservationStatus>())
                            {
                                var statusValue = ((int)status).ToString();
                                var statusText = Hotel.Helpers.ReservationUiHelper.GetReservationStatusText(status);

                                if (status == Hotel.Enums.ReservationStatus.CheckedOut)
                                {
                                    if (Model.IsPaid)
                                    {
                                        <option value="@statusValue" selected="@(status == Model.Status ? "selected" : null)">@statusText</option>
                                    }
                                }
                                else
                                {
                                    <option value="@statusValue" selected="@(status == Model.Status ? "selected" : null)">@statusText</option>
                                }
                            }
                        </select>
                        <span asp-validation-for="Status" class="text-danger"></span>
                        <div id="checkedOutHint" class="form-text text-danger @(Model.IsPaid ? "d-none" : "")">
                            Опцията „Напуснал“ се показва само когато резервацията е маркирана като платена.
                        </div>
                    </div>

                    <div class="col-md-4 d-flex align-items-end">
                        <div class="form-check mt-4">
                            <input asp-for="IsPaid" class="form-check-input" id="IsPaid" />
                            <label asp-for="IsPaid" class="form-check-label">Платено</label>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="TotalAmount" class="form-label">Сума</label>
                        <input asp-for="TotalAmount" class="form-control" readonly />
                        <div class="form-text">
                            Сумата се преизчислява автоматично според стаята и броя нощувки при запис.
                        </div>
                    </div>

                    <div class="col-12">
                        <div class="d-flex flex-wrap gap-2 mt-3">
                            <button type="submit" class="btn btn-primary">
                                Запази промените
                            </button>

                            <a asp-action="Index" class="btn btn-outline-secondary">
                                Назад
                            </a>
                        </div>
                    </div>
                </div>
            </form>

            @if (Model.Status != Hotel.Enums.ReservationStatus.Cancelled &&
                        Model.Status != Hotel.Enums.ReservationStatus.CheckedOut)
            {
                <form asp-action="Cancel" method="post" class="mt-3">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button type="submit"
                            class="btn btn-secondary"
                            onclick="return confirm('Сигурни ли сте, че искате да откажете тази резервация?');">
                        Откажи резервацията
                    </button>
                </form>
            }
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        (function () {
            const isPaidCheckbox = document.getElementById('IsPaid');
            const statusSelect = document.getElementById('Status');
            const checkedOutValue = '@((int)Hotel.Enums.ReservationStatus.CheckedOut)';
            const checkedOutText = 'Напуснал';
            const checkedOutHint = document.getElementById('checkedOutHint');

            if (!isPaidCheckbox || !statusSelect) {
                return;
            }

            function syncCheckedOutOption() {
                const existingOption = Array.from(statusSelect.options).find(option => option.value === checkedOutValue);

                if (isPaidCheckbox.checked) {
                    if (!existingOption) {
                        const option = document.createElement('option');
                        option.value = checkedOutValue;
                        option.text = checkedOutText;
                        statusSelect.appendChild(option);
                    }

                    checkedOutHint?.classList.add('d-none');
                    return;
                }

                if (statusSelect.value === checkedOutValue) {
                    statusSelect.selectedIndex = 0;
                }

                if (existingOption) {
                    existingOption.remove();
                }

                checkedOutHint?.classList.remove('d-none');
            }

            isPaidCheckbox.addEventListener('change', syncCheckedOutOption);
            syncCheckedOutOption();
        })();
    </script>
}