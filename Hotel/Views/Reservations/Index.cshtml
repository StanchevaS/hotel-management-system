@model IEnumerable<Hotel.Models.Reservation>

@{
    ViewData["Title"] = "Резервации";
}

<div class="container py-4">
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-2">
        <h1 class="mb-0">Резервации</h1>
        <div class="d-flex flex-wrap gap-2">
            <a asp-action="Create" class="btn btn-primary">Нова резервация</a>
            <a asp-action="Calendar" class="btn btn-outline-primary">Календар</a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">
            @TempData["SuccessMessage"]
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">
            @TempData["ErrorMessage"]
        </div>
    }

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form asp-action="Index" method="get" class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label">Търсене</label>
                    <input type="text"
                           name="searchTerm"
                           value="@ViewBag.SearchTerm"
                           class="form-control"
                           placeholder="Име или телефон" />
                </div>

                <div class="col-md-2">
                    <label class="form-label">Настаняване от</label>
                    <input type="date"
                           name="checkIn"
                           value="@(ViewBag.CheckIn != null ? ((DateTime)ViewBag.CheckIn).ToString("yyyy-MM-dd") : "")"
                           class="form-control" />
                </div>

                <div class="col-md-2">
                    <label class="form-label">Напускане до</label>
                    <input type="date"
                           name="checkOut"
                           value="@(ViewBag.CheckOut != null ? ((DateTime)ViewBag.CheckOut).ToString("yyyy-MM-dd") : "")"
                           class="form-control" />
                </div>

                <div class="col-md-2">
                    <label class="form-label">Стая</label>
                    <select name="roomId" class="form-select" asp-items="ViewBag.RoomList">
                        <option value="">Всички</option>
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label">Сортиране</label>
                    <select name="sortOrder" class="form-select">
                        <option value="" selected="@(ViewBag.SortOrder == null)">По подразбиране</option>
                        <option value="room_asc" selected="@(ViewBag.SortOrder == "room_asc")">Стая ↑</option>
                        <option value="room_desc" selected="@(ViewBag.SortOrder == "room_desc")">Стая ↓</option>
                        <option value="guest_asc" selected="@(ViewBag.SortOrder == "guest_asc")">Гост ↑</option>
                        <option value="guest_desc" selected="@(ViewBag.SortOrder == "guest_desc")">Гост ↓</option>
                        <option value="checkin_asc" selected="@(ViewBag.SortOrder == "checkin_asc")">Настаняване ↑</option>
                        <option value="checkin_desc" selected="@(ViewBag.SortOrder == "checkin_desc")">Настаняване ↓</option>
                    </select>
                </div>

                <div class="col-md-1 d-grid">
                    <button type="submit" class="btn btn-primary">Търси</button>
                </div>

                <div class="col-12">
                    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Изчисти филтрите</a>
                </div>
            </form>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            Няма намерени резервации.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Гост</th>
                        <th>Телефон</th>
                        <th>Стая</th>
                        <th>Гости</th>
                        <th>Настаняване</th>
                        <th>Напускане</th>
                        <th>Статус</th>
                        <th>Платено</th>
                        <th>Сума</th>
                        <th class="text-end">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.GuestName</td>
                            <td>@item.Phone</td>
                            <td>@(item.Room != null ? item.Room.Number : "-")</td>
                            <td>@item.GuestsCount</td>
                            <td>@item.CheckIn.ToString("dd.MM.yyyy")</td>
                            <td>@item.CheckOut.ToString("dd.MM.yyyy")</td>
                            <td>@Hotel.Helpers.ReservationUiHelper.GetReservationStatusText(item.Status)</td>
                            <td>
                                @if (item.IsPaid)
                                {
                                    <span class="badge bg-success">Да</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">Не</span>
                                }
                            </td>
                            <td>@item.TotalAmount.ToString("0.00") €</td>
                            <td class="text-end">
                                <div class="d-flex flex-wrap justify-content-end gap-1">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">
                                        Редакция
                                    </a>

                                    @if (item.Status != Hotel.Enums.ReservationStatus.Cancelled &&
                                                                item.Status != Hotel.Enums.ReservationStatus.CheckedOut)
                                    {
                                        <form asp-action="Cancel" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="submit"
                                                    class="btn btn-sm btn-secondary"
                                                    onclick="return confirm('Сигурни ли сте, че искате да откажете тази резервация?');">
                                                Откажи
                                            </button>
                                        </form>
                                    }

                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">
                                        Изтрий
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>