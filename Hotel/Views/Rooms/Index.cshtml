@model IEnumerable<Hotel.Models.Room>
@using Hotel.Enums
@using Hotel.Helpers

@{
    ViewData["Title"] = "Стаи в хотела";
}

<div class="container py-4">
    <div class="card shadow-sm rounded-4 border-0 p-4">
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
            <h1 class="mb-0">Стаи в хотела</h1>

            @if (User.IsInRole("Administrator"))
            {
                <a asp-action="Create" class="btn btn-primary btn-lg rounded-4">
                    Добави нова стая
                </a>
            }
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">
                @TempData["SuccessMessage"]
            </div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger">
                @TempData["ErrorMessage"]
            </div>
        }

        <form method="get" asp-action="Index" class="row g-3 align-items-end mb-4">
            <div class="col-md-3">
                <label class="form-label">Номер на стая</label>
                <input type="text"
                       name="searchNumber"
                       value="@ViewBag.SearchNumber"
                       class="form-control"
                       placeholder="Пример: 101" />
            </div>

            <div class="col-md-2">
                <label class="form-label">Тип стая</label>
                <select name="typeFilter" class="form-select" asp-items="ViewBag.RoomTypes">
                    <option value="">-- Всички --</option>
                </select>
            </div>

            <div class="col-md-2">
                <label class="form-label">Статус</label>
                <select name="statusFilter" class="form-select" asp-items="ViewBag.RoomStatuses">
                    <option value="">-- Всички --</option>
                </select>
            </div>

            <div class="col-md-2">
                <label class="form-label">Сортиране</label>
                <select name="sortOrder" class="form-select">
                    <option value="" selected="@(ViewBag.SortOrder == null)">Номер ↑</option>
                    <option value="number_desc" selected="@(ViewBag.SortOrder == "number_desc")">Номер ↓</option>
                    <option value="price_asc" selected="@(ViewBag.SortOrder == "price_asc")">Цена ↑</option>
                    <option value="price_desc" selected="@(ViewBag.SortOrder == "price_desc")">Цена ↓</option>
                    <option value="status_asc" selected="@(ViewBag.SortOrder == "status_asc")">Статус ↑</option>
                    <option value="status_desc" selected="@(ViewBag.SortOrder == "status_desc")">Статус ↓</option>
                </select>
            </div>

            <div class="col-md-3 d-flex gap-2">
                <button type="submit" class="btn btn-primary">Приложи</button>
                <a asp-action="Index" class="btn btn-secondary">Изчисти</a>
            </div>
        </form>

        <div class="table-responsive">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th>Номер</th>
                        <th>Тип стая</th>
                        <th>Капацитет</th>
                        <th>Цена на нощувка</th>
                        <th>Статус</th>
                        <th>Резервация</th>
                        <th>Управление</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var room in Model)
                        {
                            <tr>
                                <td>@room.Number</td>
                                <td>@RoomUiHelper.GetRoomTypeText(room.Type)</td>
                                <td>@room.Capacity гости</td>
                                <td>@room.PricePerNight.ToString("0.00") €</td>
                                <td>
                                    <span class="@RoomUiHelper.GetRoomStatusClass(room.Status)">
                                        @RoomUiHelper.GetRoomStatusText(room.Status)
                                    </span>
                                </td>
                                <td>
                                    @if (room.Status == RoomStatus.Available)
                                    {
                                        <a asp-controller="Reservations"
                                           asp-action="Create"
                                           asp-route-roomId="@room.Id"
                                           class="btn btn-sm btn-primary rounded-4">
                                            Резервирай
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td>
                                    <div class="d-flex flex-wrap gap-2">
                                        @if (User.IsInRole("Administrator"))
                                        {
                                            <a asp-action="Edit" asp-route-id="@room.Id" class="btn btn-sm btn-warning rounded-4">
                                                Редакция
                                            </a>

                                            <a asp-action="Delete" asp-route-id="@room.Id" class="btn btn-sm btn-danger rounded-4">
                                                Изтрий
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Няма достъп</span>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">
                                Няма намерени стаи.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>